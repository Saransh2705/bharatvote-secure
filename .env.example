# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email Service (Resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=your-email@yourdomain.com
EMAIL_FROM_NAME=BharatVote

# NextAuth Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secure-random-secret-key-minimum-32-characters

# Optional: Face Verification API
# FACE_VERIFICATION_API_URL=https://your-face-api-url.com
# FACE_VERIFICATION_API_KEY=your-face-api-key

# Optional: SMS/OTP Service (MSG91, Twilio, etc.)
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=BHARAT

# Optional: Google Maps API (for booth locator)
# Get from: https://console.cloud.google.com/
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Aadhaar Integration (Government API)
# AADHAAR_API_KEY=your-aadhaar-api-key
# AADHAAR_API_SECRET=your-aadhaar-secret

# Application Settings
NODE_ENV=development
